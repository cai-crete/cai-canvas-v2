# ── 서버사이드 전용 키 (NEXT_PUBLIC_ prefix 절대 금지) ──────────────────────
# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# V-World API Key (서버사이드 — vworld-map route.ts 사용)
# V-World 개발자센터에서 발급: https://www.vworld.kr/dev/v4dv_apikey_s001.do
# 등록 도메인과 일치해야 합니다
VWORLD_API_KEY=your_vworld_api_key_here

# ── 클라이언트 공개 키 (브라우저에서 직접 사용, 노출됨을 인지할 것) ──────────
# V-World 공개 키 — 지적도 Vector 타일 (CadastralMapView.tsx)
# 등록 도메인에서만 작동하므로 타 도메인에서 무단 사용 불가
NEXT_PUBLIC_VWORLD_KEY=your_vworld_api_key_here

# V-World 3D WebGL SDK 키 (Map3DView.tsx — SDK 스크립트 URL에 포함)
# 위 VWORLD_API_KEY와 동일한 키를 사용해도 무방
NEXT_PUBLIC_VWORLD_API_KEY=your_vworld_api_key_here
